# Node.js / Backend
# ------------------------------------------------------------
node_modules/
dist/
*.log
npm-debug.log*
# Prisma generated client
03_Source_Code/backend/src/generated/

# ------------------------------------------------------------
# TypeScript compiled artifacts (jika tsc dijalankan tanpa outDir)
